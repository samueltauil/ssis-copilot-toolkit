                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT c.CustomerID, p.FirstName, p.LastName, e.EmailAddress, c.StoreID, c.TerritoryID, CAST(c.AccountNumber AS NVARCHAR(10)) AS AccountNumber FROM Sales.Customer c LEFT JOIN Person.Person p ON p.BusinessEntityID = c.PersonID LEFT JOIN Person.EmailAddress e ON e.BusinessEntityID = c.PersonID;</property>
