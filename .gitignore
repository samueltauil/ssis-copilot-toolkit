# --- SSIS / Visual Studio build artifacts ---
bin/
obj/
*.suo
*.user
*.dtproj.user
*.sln.docstates
.vs/

# --- Generated SSIS project files (regenerated by tools/New-SsisProject.ps1) ---
templates/ssis-project/*.dtproj
templates/ssis-project/Project.params
templates/ssis-project/ConnectionManagers/*.conmgr

# --- Generated demo outputs (recreated during the walkthrough) ---
templates/ssis-project/Packages/*.dtsx
templates/sql/validate-*.sql
templates/docs/*.md
!templates/docs/README.md

# --- Managed-OM host binary (built on demand by Build-SsisOmHost.ps1) ---
tools/lib/SsisOmHost/SsisOmHost.exe

# --- Build outputs ---
out/
publish/
*.ispac

# --- PowerShell ---
*.ps1xml.cache

# --- Pester ---
TestResults/
coverage.xml
*.cobertura.xml

# --- OS / editor noise ---
Thumbs.db
.DS_Store
*.swp
*~

# --- Secrets ---
.env
.env.*
!.env.example
*.pfx
*.snk

# --- Local SSISDB exports ---
*.ispac.local
local-overrides/

# --- VS Code workspace per-user state ---
.vscode/*.local.json
